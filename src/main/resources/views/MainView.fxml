<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Menu?>
<?import javafx.scene.control.MenuBar?>
<?import javafx.scene.control.MenuItem?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.SplitPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="br.com.dmsouza.financas.gui.controller.MainViewController">
   <center>
      <SplitPane dividerPositions="0.5">
         <items>
            <ScrollPane prefHeight="200.0" prefWidth="200.0">
              <content>
                <AnchorPane minHeight="0.0" minWidth="0.0" prefHeight="200.0" prefWidth="200.0" />
              </content>
            </ScrollPane>
            <VBox fx:id="containerTableView" alignment="TOP_LEFT" prefHeight="375.0" prefWidth="718.0">
               <children>
                  <TableView fx:id="tableViewFonteDeRecurso">
                     <columns>
                        <TableColumn fx:id="tableColumnCodigo" prefWidth="96.0" text="Código" />
                        <TableColumn fx:id="tableColumnNome" prefWidth="233.0" text="Nome" />
                        <TableColumn fx:id="tableColumnSaldo" prefWidth="182.0" text="Saldo" />
                     </columns>
                  </TableView>
               </children>
            </VBox>
         </items>
      </SplitPane>
   </center>
   <top>
      <MenuBar maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" BorderPane.alignment="CENTER">
         <menus>
            <Menu mnemonicParsing="false" text="Cadastros">
               <items>
                  <MenuItem fx:id="menuItemFonteDeRecurso" mnemonicParsing="false" onAction="#onMenuItemFonteDeRecursoAction" text="Fontes de Recurso" />
               </items>
            </Menu>
            <Menu mnemonicParsing="false" text="Controles">
               <items>
                  <MenuItem fx:id="menuItemGerenciarCompetencias" mnemonicParsing="false" onAction="#onMenuItemGerenciarCompetenciasAction" text="Gerenciar Competências" />
               </items>
            </Menu>
            <Menu mnemonicParsing="false" text="Relatórios">
               <items>
                  <MenuItem fx:id="menuItemExtratoMensal" mnemonicParsing="false" onAction="#onMenuItemExtratoMensalAction" text="Extrato Mensal" />
               </items>
            </Menu>
            <Menu mnemonicParsing="false" text="Sobre">
               <items>
                  <MenuItem fx:id="menuItemVersao" mnemonicParsing="false" onAction="#onMenuItemVersaoAction" text="Versão" />
               </items>
            </Menu>
         </menus>
      </MenuBar>
   </top>
</BorderPane>
